# Copy to .env and fill in. Everything is optional; the app runs without email
# configured (events still show up on the dashboard, they just aren't emailed).

# --- Email (SMTP) ---
# For Gmail: use smtp.gmail.com:587 and an App Password
# (Google Account -> Security -> 2-Step Verification -> App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
# "From" address on notification emails (defaults to SMTP_USER)
EMAIL_FROM=you@gmail.com
# Comma-separated list of default recipients, seeded into the DB on first run.
# You can also manage recipients from the web UI.
EMAIL_TO=aryanwasinnyc@gmail.com

# --- App ---
# Where the SQLite database lives
DATABASE_PATH=data/watchtracker.db
# Default minutes between checks for newly added sites
DEFAULT_CHECK_INTERVAL_MINUTES=10
# Set to 0 to disable the background scheduler (e.g. when running tests)
SCHEDULER_ENABLED=1
